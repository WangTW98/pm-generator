{
  "meta": { "name": "ant-design-admin-component-rules", "version": "1.0.0" },
  "components": {
    "Button": {
      "height": { "sm": 32, "md": 40, "lg": 44 },
      "paddingX": 16,
      "radius": 6,
      "primary": { "fill": "color.primary", "text": "#FFFFFF" },
      "default": { "fill": "color.surface", "text": "color.textPrimary", "stroke": "color.border" }
    },
    "Input": {
      "height": 40,
      "paddingX": 12,
      "radius": 6,
      "stroke": "color.border",
      "focusStroke": "color.primary",
      "placeholder": "color.textTertiary"
    },
    "Tabs": {
      "height": 40,
      "activeColor": "color.primary",
      "inactiveColor": "color.textSecondary",
      "indicatorHeight": 2
    },
    "AuthCard": {
      "width": 420,
      "padding": 32,
      "gap": 20,
      "radius": 12,
      "shadow": "shadow.md"
    },
    "QRCode": {
      "size": 180,
      "minSize": 160,
      "radius": 8
    }
  },
  "semanticPatterns": {
    "auth": {
      "requiredRegions": ["BrandValuePanel", "AuthPanel", "AuthMethodSwitch", "CredentialArea", "PrimaryAction", "AuxiliaryLinks"],
      "forbiddenRegions": ["Table", "DataFilterBar", "MarketingHero"],
      "defaultCardWidth": 420
    }
  }
}
