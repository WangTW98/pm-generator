{
  "meta": { "name": "ant-design-admin-layout-profile-schema", "version": "1.0.0" },
  "layoutProfile": {
    "required": ["layoutKey", "canvas", "shell", "pageContainer", "lockedProperties", "hash"],
    "canvas": { "width": "number", "height": "number", "background": "token" },
    "shell": {
      "topbar": { "height": "number" },
      "footer": { "height": "number" },
      "sidebar": { "width": "number|null" }
    }
  },
  "intentProfile": {
    "required": ["pageIntentKey", "regions", "componentDefaults", "lockedProperties", "hash"]
  },
  "stateGroupProfile": {
    "required": ["stateGroupKey", "sharedGeometry", "slots", "lockedProperties", "hash"]
  },
  "mergeRules": {
    "profileLockedWinsOverRendererFallback": true,
    "businessTreeWinsOverProfile": true
  }
}
