{
  "meta": { "name": "ant-design-admin-figma-render-rules", "version": "1.0.0" },
  "canvas": {
    "pcWeb": { "width": 1440, "height": 900, "background": "color.background" },
    "mobile": { "width": 390, "height": 844, "background": "color.background" }
  },
  "layoutEngine": {
    "mode": "two-pass-auto-layout",
    "defaultFrameSizing": "fixed-root-fill-children",
    "overflowPolicy": "clip-text-or-wrap-by-role",
    "appendSpacing": 120
  },
  "semanticKeyRegions": {
    "auth": ["BrandValuePanel", "AuthPanel", "AuthMethodSwitch", "CredentialArea", "PrimaryAction", "AuxiliaryLinks"]
  },
  "qaRules": {
    "failOnMissingRoot": true,
    "failOnRendererTemplateReplacement": true,
    "warnOnMissingConsistency": true,
    "maxTextOverflowLevel": "warning",
    "requiredMetadata": ["sourceNodeId", "layoutKey", "pageIntentKey", "stateGroupKey", "styleFingerprint"]
  }
}
